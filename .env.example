# --- Discord Developer Portal → your application ---------------------------
# General Information → Application ID  (this is also your OAuth2 Client ID)
VITE_DISCORD_CLIENT_ID=your_application_id

# OAuth2 → Client Secret  (SERVER ONLY — never expose this to the browser)
DISCORD_CLIENT_SECRET=your_client_secret

# Port the local API + WebSocket server listens on
PORT=3001
